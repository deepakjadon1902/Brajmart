    { "source": "/terms", "destination": "/terms/index.html" },
    { "source": "/shop", "destination": "/products/index.html" },
    { "source": "/(login|register|verify-email|verify-otp|forgot-password|oauth-callback|cart|wishlist|checkout|profile|orders|track-orders|search|compare|track-order)", "destination": "/index.html" },
    { "source": "/profile/(.*)", "destination": "/index.html" },
    { "source": "/payment-status/(.*)", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
